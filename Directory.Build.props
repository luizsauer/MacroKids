<Project>
  <!--
    Directory.Build.props
    ─────────────────────
    Fonte única da verdade para versão, configurações de build e analyzers.
    Qualquer projeto na solution herda automaticamente tudo daqui.
    Para mudar a versão: edite apenas <Version> abaixo.
  -->

  <PropertyGroup Label="Identity">
    <Authors>Luiz Sauer</Authors>
    <Company>MacroKids</Company>
    <Product>MacroKids</Product>
    <Copyright>Copyright © $([System.DateTime]::Now.Year) MacroKids</Copyright>
    <RepositoryUrl>https://github.com/luizsauer/MacroKids</RepositoryUrl>
  </PropertyGroup>

  <PropertyGroup Label="Version">
    <!-- SemVer: MAJOR.MINOR.PATCH — edite aqui para cada release -->
    <Version>0.1.1-dev</Version>
    <AssemblyVersion>0.1.1</AssemblyVersion>
    <FileVersion>0.1.1</FileVersion>
  </PropertyGroup>

  <PropertyGroup Label="Build Quality">
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AnalysisLevel>latest</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <!-- Manter false durante desenvolvimento; tornar true antes de cada release -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <!-- Ativa todas as regras de análise do .NET -->
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisMode>All</AnalysisMode>
    <!-- CA1515: app types don't need to be internal (WPF requires public partial classes) -->
    <!-- CA1852: sealed suggestion for private nested records — style preference -->
    <NoWarn>$(NoWarn);CA1515;CA1852</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Output">
    <Deterministic>true</Deterministic>
    <!-- Pasta de saída consistente para todos os projetos -->
    <AppendTargetFrameworkToOutputPath>true</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>

</Project>
