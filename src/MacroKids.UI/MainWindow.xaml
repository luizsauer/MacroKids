<Window x:Class="MacroKids.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:editor="clr-namespace:MacroKids.NodeEditor.Controls;assembly=MacroKids.NodeEditor"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="720" Width="1200"
        Background="#1E1E2E" Foreground="#FFFFFF">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MacroKids.NodeEditor;component/Themes/DarkTheme.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MacroKids.NodeEditor;component/Themes/ControlStyles.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <!-- Row 0: Top Header with logo and browser tabs -->
      <RowDefinition Height="50"/>
      <!-- Row 1: Subheader Toolbar -->
      <RowDefinition Height="45"/>
      <!-- Row 2: Main Workspace -->
      <RowDefinition Height="*"/>
      <!-- Row 3: Statusbar -->
      <RowDefinition Height="25"/>
    </Grid.RowDefinitions>

    <!-- Top Header -->
    <Border Grid.Row="0" Background="#0C1017" BorderBrush="#1F2937" BorderThickness="0,0,0,1">
      <Grid Margin="10,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Logo Area -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <Border CornerRadius="8" Background="#4F46E5" Width="32" Height="32" Margin="0,0,10,0">
            <TextBlock Text="🤖" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="MacroKids" FontWeight="ExtraBold" FontSize="18" Foreground="#FFFFFF" VerticalAlignment="Center" FontFamily="Nunito"/>
        </StackPanel>

        <!-- Browser Tabs -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="30,0,0,0">
          <Border Background="#1E293B" CornerRadius="6,6,0,0" Padding="12,8" Margin="2,0" BorderThickness="1,1,1,0" BorderBrush="#334155">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="🔷 My Project" Foreground="White" FontSize="12" FontWeight="SemiBold" FontFamily="Nunito"/>
              <Button Content="×" Background="Transparent" BorderThickness="0" Foreground="#94A3B8" Margin="8,0,0,0" FontSize="11" Padding="2,0"/>
            </StackPanel>
          </Border>
          <Border Background="#0F172A" CornerRadius="6,6,0,0" Padding="12,8" Margin="2,0">
            <TextBlock Text="New Automation" Foreground="#94A3B8" FontSize="12" FontFamily="Nunito"/>
          </Border>
          <Button Content="+" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,5"/>
        </StackPanel>

        <!-- Top Right controls -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Content="Publish" Background="#2563EB" Foreground="White" FontWeight="Bold" Padding="16,6" BorderThickness="0" FontSize="12" FontFamily="Nunito">
            <Button.Resources>
              <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="6"/>
              </Style>
            </Button.Resources>
          </Button>
          <Button Content="⚙" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" FontSize="18" Margin="15,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Subheader Action Toolbar -->
    <Border Grid.Row="1" Background="#0F172A" BorderBrush="#1F2937" BorderThickness="0,0,0,1" Padding="15,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Search block Box -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="180" Height="28" Background="#1E293B" Foreground="White" BorderBrush="#334155" Padding="8,4" FontSize="12" FontFamily="Nunito">
            <TextBox.Resources>
              <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="6"/>
              </Style>
            </TextBox.Resources>
          </TextBox>
        </StackPanel>

        <!-- Action / Debug / Execution Play Buttons -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
          <Button Content="↶" Command="{Binding CanvasViewModel.UndoCommand}" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" FontSize="18" Padding="5,0"/>
          <Button Content="↷" Command="{Binding CanvasViewModel.RedoCommand}" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" FontSize="18" Padding="5,0"/>
          
          <Border Width="1" Background="#1E293B" Margin="10,6"/>

          <Button Content="▶ Play" Command="{Binding RunFlowCommand}" Background="#15803D" Foreground="White" FontWeight="Bold" Padding="12,4" BorderThickness="0" FontSize="11" Margin="2,0" Height="28">
            <Button.Resources>
              <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="4"/>
              </Style>
            </Button.Resources>
          </Button>
          <Button Content="🐞 Debug" Background="#1E293B" Foreground="White" Padding="12,4" BorderThickness="1" BorderBrush="#334155" FontSize="11" Margin="2,0" Height="28">
            <Button.Resources>
              <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="4"/>
              </Style>
            </Button.Resources>
          </Button>
          <Button Content="⏹ Stop" Background="#991B1B" Foreground="White" Padding="12,4" BorderThickness="0" FontSize="11" Margin="2,0" Height="28">
            <Button.Resources>
              <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="4"/>
              </Style>
            </Button.Resources>
          </Button>
        </StackPanel>

        <!-- Zoom options -->
        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Content="-" Command="{Binding CanvasViewModel.ZoomOutCommand}" Background="Transparent" Foreground="White" FontSize="14" BorderThickness="0" Padding="5"/>
          <TextBlock Text="100%" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center" Margin="8,0" FontFamily="Nunito"/>
          <Button Content="+" Command="{Binding CanvasViewModel.ZoomInCommand}" Background="Transparent" Foreground="White" FontSize="14" BorderThickness="0" Padding="5"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main Workspace -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <!-- Sidebar modules buttons -->
        <ColumnDefinition Width="65"/>
        <!-- Sidebar blocks palette -->
        <ColumnDefinition Width="220"/>
        <!-- Node canvas area -->
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Sidebar module selector -->
      <Border Grid.Column="0" Background="#0C1017" BorderBrush="#1F2937" BorderThickness="0,0,1,0">
        <StackPanel Margin="0,15">
          <Button Content="🧩&#x0a;Blocks" Command="{Binding SelectModuleCommand}" CommandParameter="Blocks" Foreground="White" Background="#1E293B" BorderThickness="0" Height="60" Margin="0,4" FontSize="11" FontFamily="Nunito"/>
          <Button Content="𝔁&#x0a;Variables" Command="{Binding SelectModuleCommand}" CommandParameter="Variables" Foreground="#94A3B8" Background="Transparent" BorderThickness="0" Height="60" Margin="0,4" FontSize="11" FontFamily="Nunito"/>
          <Button Content="𝒇𝔁&#x0a;Functions" Command="{Binding SelectModuleCommand}" CommandParameter="Functions" Foreground="#94A3B8" Background="Transparent" BorderThickness="0" Height="60" Margin="0,4" FontSize="11" FontFamily="Nunito"/>
          <Button Content="🖼️&#x0a;Images" Command="{Binding SelectModuleCommand}" CommandParameter="Images" Foreground="#94A3B8" Background="Transparent" BorderThickness="0" Height="60" Margin="0,4" FontSize="11" FontFamily="Nunito"/>
          <Button Content="🔍&#x0a;OCR" Command="{Binding SelectModuleCommand}" CommandParameter="OCR" Foreground="#94A3B8" Background="Transparent" BorderThickness="0" Height="60" Margin="0,4" FontSize="11" FontFamily="Nunito"/>
          <Button Content="✨&#x0a;AI" Command="{Binding SelectModuleCommand}" CommandParameter="AI" Foreground="#94A3B8" Background="Transparent" BorderThickness="0" Height="60" Margin="0,4" FontSize="11" FontFamily="Nunito"/>
          <Button Content="⚡&#x0a;Events" Command="{Binding SelectModuleCommand}" CommandParameter="Events" Foreground="#94A3B8" Background="Transparent" BorderThickness="0" Height="60" Margin="0,4" FontSize="11" FontFamily="Nunito"/>
          <Button Content="⚙️&#x0a;Settings" Command="{Binding SelectModuleCommand}" CommandParameter="Settings" Foreground="#94A3B8" Background="Transparent" BorderThickness="0" Height="60" Margin="0,4" FontSize="11" FontFamily="Nunito"/>
        </StackPanel>
      </Border>

      <!-- Sidebar blocks list -->
      <Border Grid.Column="1" Background="#0F172A" BorderBrush="#1F2937" BorderThickness="0,0,1,0" Padding="10">
        <Grid>
          <ListBox ItemsSource="{Binding GroupedNodes}" Background="Transparent" BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,5">
                  <!-- Category Header -->
                  <TextBlock Text="{Binding Key}" FontSize="12" FontWeight="Bold" Foreground="#38BDF8" Margin="0,5" FontFamily="Nunito"/>
                  
                  <!-- Items under this Category -->
                  <ItemsControl ItemsSource="{Binding}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="#1E293B" CornerRadius="8" Padding="8" Margin="0,4" BorderThickness="1" BorderBrush="#334155">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                              <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" FontSize="12" FontFamily="Nunito"/>
                              <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="+" Command="{Binding DataContext.AddNodeToCanvasCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    CommandParameter="{Binding}" Background="#2563EB" Foreground="White" Width="20" Height="20" BorderThickness="0" FontWeight="Bold" VerticalAlignment="Center"/>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- Canvas Area -->
      <editor:NodeEditorControl Grid.Column="2" DataContext="{Binding CanvasViewModel}"/>
    </Grid>

    <!-- Footer StatusBar -->
    <Border Grid.Row="3" Background="#0C1017" BorderBrush="#1F2937" BorderThickness="0,1,0,0" Padding="15,2">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center" FontFamily="Nunito"/>
    </Border>
  </Grid>
</Window>

