<Window x:Class="MacroKids.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:editor="clr-namespace:MacroKids.NodeEditor.Controls;assembly=MacroKids.NodeEditor"
        xmlns:services="clr-namespace:MacroKids.UI.Services"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="720"
        Width="1280"
        Background="{DynamicResource BrushBackground}"
        Foreground="{DynamicResource BrushTextPrimary}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="45" />
            <RowDefinition Height="*" />
            <RowDefinition Height="25" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushSurfaceVariant}" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{Binding LogoIcon}" Width="148" Height="32" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="24,0,0,0">
                    <ItemsControl ItemsSource="{Binding Pages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2,0" CornerRadius="6,6,0,0" Padding="10,8" BorderThickness="1,1,1,0" BorderBrush="#334155">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BrushSurface}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BrushSurfaceVariant}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                HorizontalContentAlignment="Left">
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="12" FontWeight="SemiBold" FontFamily="Nunito" />
                                        </Button>

                                        <Button Grid.Column="1"
                                                Command="{Binding DataContext.ClosePageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="×"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Margin="8,0,0,0"
                                                FontSize="11"
                                                Padding="2,0"
                                                ToolTip="{Binding Translations[TabClose], Source={x:Static services:LocalizationManager.Instance}}"
                                                IsEnabled="{Binding CanClose}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                <Button Content="+"
                            Command="{Binding AddPageCommand}"
                            Background="Transparent"
                        Foreground="{DynamicResource BrushTextSecondary}"
                            BorderThickness="0"
                            FontSize="16"
                            VerticalAlignment="Center"
                            Margin="8,0,0,5"
                            ToolTip="{Binding Translations[TabAdd], Source={x:Static services:LocalizationManager.Instance}}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Margin="0,0,15,0" VerticalAlignment="Center">
                    <Button x:Name="LanguageButton"
                            Command="{Binding ToggleLanguageMenuCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="34"
                            Height="34"
                            Padding="0"
                        ToolTip="{Binding Translations[TooltipChangeLanguage], Source={x:Static services:LocalizationManager.Instance}}">
                        <Border CornerRadius="17"
                                Width="32"
                                Height="32"
                                Background="{DynamicResource BrushSurface}"
                                BorderBrush="{DynamicResource BrushSurfaceVariant}"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <Image Source="{Binding SelectedLanguage.Icon}" Stretch="UniformToFill" />
                        </Border>
                    </Button>

                    <Popup PlacementTarget="{Binding ElementName=LanguageButton}"
                           Placement="Bottom"
                           StaysOpen="False"
                           IsOpen="{Binding IsLanguageMenuOpen, Mode=TwoWay}"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource BrushSurface}"
                                BorderBrush="{DynamicResource BrushSurfaceVariant}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="8"
                                Margin="0,6,0,0"
                                SnapsToDevicePixels="True">
                            <ItemsControl ItemsSource="{Binding Languages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="LanguageOption_Click"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="4"
                                                Margin="2"
                                                ToolTip="{Binding Name}">
                                            <Border Width="30"
                                                    Height="30"
                                                    CornerRadius="15"
                                                    ClipToBounds="True"
                                                    BorderBrush="{DynamicResource BrushSurfaceVariant}"
                                                    BorderThickness="1">
                                                <Image Source="{Binding Icon}" Stretch="UniformToFill" />
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>
                </Grid>

                <Button Command="{Binding ToggleThemeCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="28"
                        Height="28"
                        Margin="0,0,15,0"
                        VerticalAlignment="Center"
                        Padding="0"
                        ToolTip="{Binding Translations[TooltipToggleTheme], Source={x:Static services:LocalizationManager.Instance}}">
                    <Grid Width="22" Height="22">
                        <Rectangle Fill="{DynamicResource BrushTextPrimary}">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="{Binding ThemeIcon}" Stretch="Uniform" />
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Grid>
                </Button>

                <Button Command="{Binding SaveProjectCommand}"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"
                        Padding="16,6"
                            BorderThickness="0"
                            FontSize="12"
                            FontFamily="Nunito">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6" />
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="{Binding Translations[ButtonSave], Source={x:Static services:LocalizationManager.Instance}}" />
                    </Button>

                    <Button Command="{Binding SelectModuleCommand}" CommandParameter="Settings"
                            Background="Transparent"
                            Foreground="#94A3B8"
                            BorderThickness="0"
                            FontSize="18"
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="{Binding Translations[TooltipSettings], Source={x:Static services:LocalizationManager.Instance}}">
                        <TextBlock Text="⚙" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource BrushSurfaceVariant}" BorderBrush="{DynamicResource BrushSurfaceVariant}" BorderThickness="0,0,0,1" Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="190"
                             Height="28"
                             Background="{DynamicResource BrushSurface}"
                             Foreground="{DynamicResource BrushTextPrimary}"
                             BorderBrush="{DynamicResource BrushSurfaceVariant}"
                             BorderThickness="1"
                             Padding="25,4,8,4"
                             FontSize="12"
                             FontFamily="Nunito">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6" />
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBlock Text="🔍"
                               Foreground="#64748B"
                               FontSize="11"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               IsHitTestVisible="False" />
                    <TextBlock Text="{Binding Translations[SearchPlaceholder], Source={x:Static services:LocalizationManager.Instance}}"
                               Foreground="#64748B"
                               FontSize="11"
                               Margin="25,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               FontFamily="Nunito">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Button Content="⛶" Command="{Binding CanvasViewModel.FitToContentCommand}" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" FontSize="15" Padding="6,4" ToolTip="{Binding Translations[TooltipFitCanvas], Source={x:Static services:LocalizationManager.Instance}}" />
                    <Button Content="🌐" Command="{Binding CanvasViewModel.ToggleGridCommand}" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" FontSize="15" Padding="6,4" ToolTip="{Binding Translations[TooltipToggleGrid], Source={x:Static services:LocalizationManager.Instance}}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Button Content="↶" Command="{Binding CanvasViewModel.UndoCommand}" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" FontSize="18" Padding="5,0" ToolTip="{Binding Translations[TooltipUndo], Source={x:Static services:LocalizationManager.Instance}}" />
                    <Button Content="↷" Command="{Binding CanvasViewModel.RedoCommand}" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" FontSize="18" Padding="5,0" ToolTip="{Binding Translations[TooltipRedo], Source={x:Static services:LocalizationManager.Instance}}" />

                    <Border Width="1" Background="{DynamicResource BrushSurfaceVariant}" Margin="10,6" />

                    <Button Command="{Binding RunFlowCommand}" Background="#15803D" Foreground="White" FontWeight="Bold" Padding="12,4" BorderThickness="0" FontSize="11" Margin="2,0" Height="28">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶ " />
                            <TextBlock Text="{Binding Translations[ButtonPlay], Source={x:Static services:LocalizationManager.Instance}}" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding DebugFlowCommand}" Background="{DynamicResource BrushSurface}" Foreground="{DynamicResource BrushTextPrimary}" Padding="12,4" BorderThickness="1" BorderBrush="{DynamicResource BrushSurfaceVariant}" FontSize="11" Margin="2,0" Height="28">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🐞 " />
                            <TextBlock Text="{Binding Translations[ButtonDebug], Source={x:Static services:LocalizationManager.Instance}}" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding StopFlowCommand}" Background="#991B1B" Foreground="White" Padding="12,4" BorderThickness="0" FontSize="11" Margin="2,0" Height="28">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏹ " />
                            <TextBlock Text="{Binding Translations[ButtonStop], Source={x:Static services:LocalizationManager.Instance}}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="-" Command="{Binding CanvasViewModel.ZoomOutCommand}" Background="Transparent" Foreground="{DynamicResource BrushTextPrimary}" FontSize="14" BorderThickness="0" Padding="5" ToolTip="{Binding Translations[TooltipZoomOut], Source={x:Static services:LocalizationManager.Instance}}" />
                    <TextBlock Text="{Binding CanvasViewModel.ZoomLabel}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" VerticalAlignment="Center" Margin="8,0" FontFamily="Nunito" />
                    <Button Content="+" Command="{Binding CanvasViewModel.ZoomInCommand}" Background="Transparent" Foreground="{DynamicResource BrushTextPrimary}" FontSize="14" BorderThickness="0" Padding="5" ToolTip="{Binding Translations[TooltipZoomIn], Source={x:Static services:LocalizationManager.Instance}}" />
                </StackPanel>

                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Button Click="SearchCanvas_Click" Content="🔍" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" FontSize="13" Padding="6,4" ToolTip="{Binding Translations[TooltipSearchCanvas], Source={x:Static services:LocalizationManager.Instance}}" />
                    <Button Command="{Binding SaveProjectCommand}" Content="📤" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" FontSize="13" Padding="6,4" ToolTip="{Binding Translations[TooltipSaveProject], Source={x:Static services:LocalizationManager.Instance}}" />
                    <Button Click="ConnectLink_Click" Content="🔗" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" FontSize="13" Padding="6,4" ToolTip="{Binding Translations[TooltipConnectLink], Source={x:Static services:LocalizationManager.Instance}}" />
                    <Button Click="Fullscreen_Click" Content="⛶" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" FontSize="13" Padding="6,4" ToolTip="{Binding Translations[TooltipFullscreen], Source={x:Static services:LocalizationManager.Instance}}" />
                    <Button Click="LockCanvas_Click" Content="🔒" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" FontSize="13" Padding="6,4" ToolTip="{Binding Translations[TooltipLockCanvas], Source={x:Static services:LocalizationManager.Instance}}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushSurfaceVariant}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,12">
                    <Button Command="{Binding SelectModuleCommand}" CommandParameter="Blocks" Foreground="White" Background="#2563EB" BorderThickness="0" Height="56" Margin="4" Padding="0,6">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🧩" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Translations[ModuleBlocks], Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" HorizontalAlignment="Center" FontFamily="Nunito" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SelectModuleCommand}" CommandParameter="Variables" Foreground="White" Background="#8B5CF6" BorderThickness="0" Height="56" Margin="4" Padding="0,6">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="𝔁" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Translations[ModuleVariables], Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" HorizontalAlignment="Center" FontFamily="Nunito" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SelectModuleCommand}" CommandParameter="Functions" Foreground="White" Background="#0EA5E9" BorderThickness="0" Height="56" Margin="4" Padding="0,6">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="𝒇𝔁" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Translations[ModuleFunctions], Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" HorizontalAlignment="Center" FontFamily="Nunito" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SelectModuleCommand}" CommandParameter="Images" Foreground="White" Background="#3B82F6" BorderThickness="0" Height="56" Margin="4" Padding="0,6">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🖼️" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Translations[ModuleImages], Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" HorizontalAlignment="Center" FontFamily="Nunito" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SelectModuleCommand}" CommandParameter="OCR" Foreground="White" Background="#14B8A6" BorderThickness="0" Height="56" Margin="4" Padding="0,6">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Translations[ModuleOCR], Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" HorizontalAlignment="Center" FontFamily="Nunito" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SelectModuleCommand}" CommandParameter="AI" Foreground="White" Background="#A855F7" BorderThickness="0" Height="56" Margin="4" Padding="0,6">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="✨" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Translations[ModuleAI], Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" HorizontalAlignment="Center" FontFamily="Nunito" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SelectModuleCommand}" CommandParameter="Events" Foreground="White" Background="#EC4899" BorderThickness="0" Height="56" Margin="4" Padding="0,6">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Translations[ModuleEvents], Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" HorizontalAlignment="Center" FontFamily="Nunito" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SelectModuleCommand}" CommandParameter="Settings" Foreground="White" Background="#64748B" BorderThickness="0" Height="56" Margin="4" Padding="0,6">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⚙️" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Translations[ModuleSettings], Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" HorizontalAlignment="Center" FontFamily="Nunito" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource BrushSurfaceVariant}" BorderBrush="{DynamicResource BrushSurfaceVariant}" BorderThickness="0,0,1,0" Padding="10">
                <ListBox ItemsSource="{Binding GroupedNodes}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,5">
                                <TextBlock Text="{Binding Key}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}" Margin="0,5" FontFamily="Nunito" />
                                <ItemsControl ItemsSource="{Binding}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Padding="10" Margin="0,4" BorderThickness="0" Background="{Binding CategoryColor}"
                                                    PreviewMouseLeftButtonDown="PaletteItem_PreviewMouseLeftButtonDown"
                                                    PreviewMouseMove="PaletteItem_PreviewMouseMove"
                                                    Cursor="Hand">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" FontSize="11" FontFamily="Nunito" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Content="+"
                                                            Command="{Binding DataContext.AddNodeToCanvasCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#1E293B"
                                                            Foreground="White"
                                                            Width="20"
                                                            Height="20"
                                                            BorderThickness="0"
                                                            FontWeight="Bold"
                                                            VerticalAlignment="Center">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="10" />
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <editor:NodeEditorControl Grid.Column="2"
                                      x:Name="EditorView"
                                      DataContext="{Binding CanvasViewModel}" />

            <Border Grid.Column="3" Background="{DynamicResource BrushSurfaceVariant}" BorderBrush="{DynamicResource BrushSurfaceVariant}" BorderThickness="1,0,0,0" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding Translations[InspectorTitle], Source={x:Static services:LocalizationManager.Instance}}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontSize="13"
                               FontWeight="Bold"
                               FontFamily="Nunito"
                               Margin="0,0,0,10" />

                    <Grid Grid.Row="1">
                        <TextBlock Text="{Binding Translations[InspectorEmpty], Source={x:Static services:LocalizationManager.Instance}}"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   TextWrapping="Wrap"
                                   FontFamily="Nunito">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNode}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ContentControl Content="{Binding SelectedNode}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Metadata.Name}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="18" FontWeight="Bold" FontFamily="Nunito" />
                                        <TextBlock Text="{Binding Metadata.Description}" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" Margin="0,4,0,12" FontFamily="Nunito" />
                                        <TextBlock Text="{Binding Metadata.Category}" Foreground="{DynamicResource BrushPrimary}" FontSize="11" Margin="0,0,0,12" FontFamily="Nunito" />

                                        <CheckBox Content="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=Translations[InspectorDisabled]}"
                                                  IsChecked="{Binding IsDisabled, Mode=TwoWay}"
                                                  Foreground="{DynamicResource BrushTextPrimary}"
                                                  Margin="0,0,0,10" />

                                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=Translations[InspectorComment]}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="{DynamicResource BrushSurface}"
                                                 Foreground="{DynamicResource BrushTextPrimary}"
                                                 BorderBrush="{DynamicResource BrushSurfaceVariant}"
                                                 BorderThickness="1"
                                                 Padding="8,6"
                                                 Margin="0,0,0,12" />

                                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=Translations[InspectorInputs]}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" Margin="0,0,0,6" />
                                        <ItemsControl ItemsSource="{Binding InputPins}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="11" Margin="0,0,0,3" />
                                                        <TextBox Background="{DynamicResource BrushSurface}"
                                                                 Foreground="{DynamicResource BrushTextPrimary}"
                                                                 BorderBrush="{DynamicResource BrushSurfaceVariant}"
                                                                 BorderThickness="1"
                                                                 Padding="8,6"
                                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Button Content="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=Translations[InspectorCaptureMouse]}"
                                                Command="{Binding DataContext.PickMoveMouseCoordinatesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Visibility="{Binding DataContext.CanPickMoveMouseCoordinates, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                                                Background="{DynamicResource BrushSurface}"
                                                Foreground="{DynamicResource BrushTextPrimary}"
                                                BorderBrush="{DynamicResource BrushSurfaceVariant}"
                                                BorderThickness="1"
                                                Padding="10,6"
                                                Margin="0,0,0,12" />

                                        <Button Content="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=Translations[InspectorDeleteBlock]}"
                                                Command="{Binding DataContext.CanvasViewModel.DeleteSelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Background="#991B1B"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Padding="10,6"
                                                Margin="0,10,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushSurfaceVariant}" BorderThickness="0,1,0,0" Padding="15,2">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" VerticalAlignment="Center" FontFamily="Nunito" />
        </Border>
    </Grid>
</Window>
