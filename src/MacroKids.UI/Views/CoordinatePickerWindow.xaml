<Window x:Class="MacroKids.UI.Views.CoordinatePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#80000000" BorderBrush="#66FFFFFF" BorderThickness="1">
        <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                <TextBlock Text="Click anywhere to capture the mouse position"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />
                <TextBlock Text="Press Esc to cancel"
                           Foreground="#D1D5DB"
                           FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
