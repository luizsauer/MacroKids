<Window x:Class="MacroKids.UI.Views.RecorderOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MacroKids Recorder" 
        Height="55" 
        Width="300" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Left="20"
        Top="20">
    <Border Background="#0F172A" BorderBrush="#2563EB" BorderThickness="1.5" CornerRadius="8" Padding="10,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
 
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#EF4444" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.6" AutoReverse="True" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock x:Name="StatusText" Text="Gravando..." Foreground="White" FontSize="12" FontFamily="Nunito" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
 
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button x:Name="PauseButton" 
                        Content="Pausar" 
                        Click="PauseButton_Click" 
                        Background="#D97706" 
                        Foreground="White" 
                        BorderThickness="0" 
                        Padding="8,4"
                        FontSize="10" 
                        FontWeight="Bold"
                        FontFamily="Nunito"
                        Cursor="Hand"
                        Margin="0,0,4,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="ResumeButton" 
                        Content="Retomar" 
                        Click="ResumeButton_Click" 
                        Background="#15803D" 
                        Foreground="White" 
                        BorderThickness="0" 
                        Padding="8,4"
                        FontSize="10" 
                        FontWeight="Bold"
                        FontFamily="Nunito"
                        Cursor="Hand"
                        Visibility="Collapsed">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <Button Grid.Column="2" 
                    Content="Parar" 
                    Click="StopButton_Click" 
                    Background="#991B1B" 
                    Foreground="White" 
                    BorderThickness="0" 
                    Padding="10,4"
                    FontSize="10" 
                    FontWeight="Bold"
                    FontFamily="Nunito"
                    Cursor="Hand"
                    VerticalAlignment="Center">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4" />
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>
