<UserControl x:Class="MacroKids.NodeEditor.Controls.NodeEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MacroKids.NodeEditor.Controls"
             xmlns:vm="clr-namespace:MacroKids.NodeEditor.ViewModels"
             AllowDrop="True"
             DragOver="EditorCanvas_DragOver"
             Drop="EditorCanvas_Drop">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MacroKids.NodeEditor;component/Themes/ControlStyles.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid PreviewMouseMove="EditorCanvas_PreviewMouseMove"
        PreviewMouseLeftButtonUp="EditorCanvas_PreviewMouseLeftButtonUp">
    <!-- We put the NodeCanvas inside a ScrollViewer or just directly since we do custom panning -->
    <local:NodeCanvas x:Name="EditorCanvas" 
                      Zoom="{Binding Zoom}"
                      OffsetX="{Binding OffsetX}"
                      OffsetY="{Binding OffsetY}"
                      IsGridVisible="{Binding IsGridVisible}">
                      
              <!-- Connections (Rendered Behind Nodes) -->
              <ItemsControl ItemsSource="{Binding Connections}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Canvas />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                    <!-- Custom style with transparent over-layer for easier double click / selection -->
                    <Grid Cursor="Hand">
                      <local:ConnectionLine StartPoint="{Binding StartPoint}" EndPoint="{Binding EndPoint}" 
                                      Stroke="Transparent" StrokeThickness="14"
                                      MouseLeftButtonDown="Connection_MouseLeftButtonDown" />
                      
                      <local:ConnectionLine StartPoint="{Binding StartPoint}" EndPoint="{Binding EndPoint}" 
                                      Stroke="{Binding StrokeBrush}" StrokeThickness="4" IsHitTestVisible="False"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round">
                        <local:ConnectionLine.Style>
                          <Style TargetType="local:ConnectionLine">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsAnimating}" Value="True">
                               <Setter Property="Stroke" Value="#EAB308" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </local:ConnectionLine.Style>
                      </local:ConnectionLine>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

      <local:ConnectionLine IsHitTestVisible="False"
                            Visibility="{Binding IsConnectingPins, Converter={StaticResource BoolToVisibility}}"
                            StartPoint="{Binding ConnectionPreviewStart}"
                            EndPoint="{Binding ConnectionPreviewEnd}"
                            Stroke="#FFFFFF"
                            StrokeThickness="4"
                            StrokeStartLineCap="Round"
                            StrokeEndLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeDashArray="4,3"
                            Opacity="0.8" />

      <ItemsControl ItemsSource="{Binding Nodes}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <Canvas />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemContainerStyle>
          <Style TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding X}" />
            <Setter Property="Canvas.Top" Value="{Binding Y}" />
          </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:NodeViewModel}">
            <Border BorderThickness="1.5" CornerRadius="14" Width="215" Height="Auto" Margin="5"
                    PreviewMouseDown="Node_PreviewMouseDown"
                    MouseMove="Node_MouseMove"
                    MouseUp="Node_MouseUp"
                    Cursor="SizeAll">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="BorderBrush" Value="Transparent" />
                  <Setter Property="Background" Value="{Binding Metadata.CategoryColor}" />
                  <Setter Property="Opacity" Value="1" />
                  <Setter Property="SnapsToDevicePixels" Value="True" />
                  <Setter Property="Effect">
                    <Setter.Value>
                      <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.28" Color="#000000" />
                    </Setter.Value>
                  </Setter>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                      <Setter Property="BorderBrush" Value="#FFFFFF" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                      <Setter Property="Opacity" Value="0.55" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsExecuting}" Value="True">
                      <Setter Property="BorderBrush" Value="#EAB308" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding HasError}" Value="True">
                      <Setter Property="BorderBrush" Value="#EF4444" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              
              <Grid Margin="14,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Execution input pin (flow "in") -->
                <ItemsControl Grid.Column="0" ItemsSource="{Binding FlowInputPins}" HorizontalAlignment="Left" VerticalAlignment="Center">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <ContentControl Style="{StaticResource PinDotStyle}" Margin="-18,0,4,0"
                                      PreviewMouseLeftButtonDown="Pin_PreviewMouseLeftButtonDown"
                                      PreviewMouseLeftButtonUp="Pin_PreviewMouseLeftButtonUp"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Central Content Area -->
                <StackPanel Grid.Column="1" Margin="4,2">
                  <!-- Block Title -->
                  <TextBlock Text="{Binding Metadata.Name}" Foreground="White" FontWeight="Bold" FontFamily="Nunito" FontSize="13" Margin="0,0,0,6"/>
                  
                  <!-- Data Parameter Inputs (non-flow pins with inline textbox) -->
                  <ItemsControl ItemsSource="{Binding DataInputPins}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                          <TextBlock Text="{Binding Label}" Foreground="#E2E8F0" FontSize="10" FontFamily="Nunito" VerticalAlignment="Center" Margin="0,0,5,0" Width="60" TextTrimming="CharacterEllipsis"/>
                          
                          <!-- TextBox comum -->
                          <TextBox Width="85" Height="22" Background="#0F172A" Foreground="White" BorderThickness="0" Padding="4,2" FontSize="10" FontFamily="Nunito" VerticalContentAlignment="Center" VerticalAlignment="Center" Text="{Binding ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding IsTextInput, Converter={StaticResource BoolToVisibility}}">
                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                          </TextBox>

                          <!-- ComboBox Dropdown -->
                          <ComboBox Width="85" Height="22" Background="#0F172A" Foreground="White" BorderThickness="0" Padding="4,2" FontSize="10" FontFamily="Nunito" VerticalContentAlignment="Center" VerticalAlignment="Center" ItemsSource="{Binding Options}" SelectedItem="{Binding Value, Mode=TwoWay}" Visibility="{Binding IsDropdown, Converter={StaticResource BoolToVisibility}}">
                            <ComboBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></ComboBox.Resources>
                          </ComboBox>

                          <!-- TextBox especial para Captura de Teclas -->
                          <TextBox Width="85" Height="22" Background="#1E1B4B" Foreground="#38BDF8" BorderBrush="#38BDF8" BorderThickness="1" Padding="4,2" FontSize="10" FontFamily="Nunito" FontWeight="Bold" VerticalContentAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" Cursor="Hand" Text="{Binding ValueText, Mode=OneWay}" ToolTip="Clique aqui e pressione qualquer tecla no teclado" PreviewKeyDown="KeyCaptureTextBox_PreviewKeyDown" Visibility="{Binding IsKeyCapture, Converter={StaticResource BoolToVisibility}}">
                            <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                          </TextBox>
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>

                <!-- Right: Execution output pin (flow "done") -->
                <ItemsControl Grid.Column="2" ItemsSource="{Binding FlowOutputPins}" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <ContentControl Style="{StaticResource PinDotStyle}" Margin="4,0,-18,0"
                                      PreviewMouseLeftButtonDown="Pin_PreviewMouseLeftButtonDown"
                                      PreviewMouseLeftButtonUp="Pin_PreviewMouseLeftButtonUp"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </local:NodeCanvas>
  </Grid>
</UserControl>
