<UserControl x:Class="MacroKids.NodeEditor.Controls.NodeEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MacroKids.NodeEditor.Controls"
             xmlns:vm="clr-namespace:MacroKids.NodeEditor.ViewModels">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MacroKids.NodeEditor;component/Themes/DarkTheme.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MacroKids.NodeEditor;component/Themes/ControlStyles.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid>
    <!-- We put the NodeCanvas inside a ScrollViewer or just directly since we do custom panning -->
    <local:NodeCanvas x:Name="EditorCanvas" 
                      Zoom="{Binding Zoom}"
                      OffsetX="{Binding OffsetX}"
                      OffsetY="{Binding OffsetY}">
                      
      <!-- Connections (Rendered Behind Nodes) -->
      <ItemsControl ItemsSource="{Binding Connections}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <Canvas />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
            <local:ConnectionLine StartPoint="{Binding StartPoint}" EndPoint="{Binding EndPoint}" 
                                  Stroke="#8B5CF6" StrokeThickness="3">
              <local:ConnectionLine.Style>
                <Style TargetType="local:ConnectionLine">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAnimating}" Value="True">
                      <Setter Property="Stroke" Value="#EAB308" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </local:ConnectionLine.Style>
            </local:ConnectionLine>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <ItemsControl ItemsSource="{Binding Nodes}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <Canvas />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemContainerStyle>
          <Style TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding X}" />
            <Setter Property="Canvas.Top" Value="{Binding Y}" />
          </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:NodeViewModel}">
            <Border BorderThickness="2" CornerRadius="8" Background="#252538" Width="180" Height="Auto" Margin="5"
                    PreviewMouseDown="Node_PreviewMouseDown"
                    MouseMove="Node_MouseMove"
                    MouseUp="Node_MouseUp"
                    Cursor="SizeAll">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="BorderBrush" Value="#2D2D44" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                      <Setter Property="BorderBrush" Value="#3B82F6" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsExecuting}" Value="True">
                      <Setter Property="BorderBrush" Value="#22C55E" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding HasError}" Value="True">
                      <Setter Property="BorderBrush" Value="#EF4444" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Header - Dynamically colored by Category -->
                <Border Grid.Row="0" CornerRadius="6,6,0,0" Padding="10,8">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="#2D2D44"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding Metadata.Category}" Value="Mouse">
                          <Setter Property="Background" Value="{StaticResource BrushMouse}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Metadata.Category}" Value="Keyboard">
                          <Setter Property="Background" Value="{StaticResource BrushKeyboard}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Metadata.Category}" Value="Loops">
                          <Setter Property="Background" Value="{StaticResource BrushLoops}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Metadata.Category}" Value="Events">
                          <Setter Property="Background" Value="{StaticResource BrushEvents}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Metadata.Category}" Value="Variables">
                          <Setter Property="Background" Value="{StaticResource BrushVariables}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <TextBlock Text="{Binding Metadata.Name}" Foreground="White" FontWeight="Bold" FontFamily="Nunito" FontSize="13"/>
                </Border>
                
                <!-- Content / Pins -->
                <StackPanel Grid.Row="1" Margin="8">
                  <TextBlock Text="{Binding Metadata.Description}" TextWrapping="Wrap" FontSize="11" Foreground="#8F9CAE" Margin="0,0,0,10"/>
                  
                  <!-- Inputs -->
                  <ItemsControl ItemsSource="{Binding Metadata.Inputs}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0,3">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          
                          <!-- Connection Pin -->
                          <ContentControl Style="{StaticResource PinDotStyle}" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                          
                          <!-- Label -->
                          <TextBlock Text="{Binding Label}" Foreground="#FFFFFF" Grid.Column="1" VerticalAlignment="Center" FontSize="11" FontFamily="Nunito"/>
                          
                          <!-- Editable Input Box (for numbers/keys) -->
                          <TextBox Grid.Column="2" Width="50" Height="20" Background="#1E1E2E" Foreground="#FFFFFF" BorderBrush="#2D2D44" 
                                   BorderThickness="1" Margin="5,0,0,0" Padding="2,0" FontSize="10" VerticalAlignment="Center"
                                   HorizontalContentAlignment="Center"/>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <!-- Outputs -->
                  <ItemsControl ItemsSource="{Binding Metadata.Outputs}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0,3">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Text="{Binding Label}" Foreground="#FFFFFF" Grid.Column="0" TextAlignment="Right" VerticalAlignment="Center" FontSize="11" FontFamily="Nunito" Margin="0,0,5,0"/>
                          <ContentControl Style="{StaticResource PinDotStyle}" Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </local:NodeCanvas>
  </Grid>
</UserControl>
