<UserControl x:Class="MacroKids.NodeEditor.Controls.NodeEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MacroKids.NodeEditor.Controls"
             xmlns:vm="clr-namespace:MacroKids.NodeEditor.ViewModels">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MacroKids.NodeEditor;component/Themes/LightTheme.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MacroKids.NodeEditor;component/Themes/ControlStyles.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid>
    <!-- We put the NodeCanvas inside a ScrollViewer or just directly since we do custom panning -->
    <local:NodeCanvas x:Name="EditorCanvas" 
                      Zoom="{Binding Zoom}"
                      OffsetX="{Binding OffsetX}"
                      OffsetY="{Binding OffsetY}"
                      IsGridVisible="{Binding IsGridVisible}">
                      
      <!-- Connections (Rendered Behind Nodes) -->
      <ItemsControl ItemsSource="{Binding Connections}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <Canvas />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
            <local:ConnectionLine StartPoint="{Binding StartPoint}" EndPoint="{Binding EndPoint}" 
                              Stroke="{Binding StrokeBrush}" StrokeThickness="3"
                              MouseLeftButtonDown="Connection_MouseLeftButtonDown">
          <local:ConnectionLine.Style>
            <Style TargetType="local:ConnectionLine">
              <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAnimating}" Value="True">
                      <Setter Property="Stroke" Value="#EAB308" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </local:ConnectionLine.Style>
            </local:ConnectionLine>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <ItemsControl ItemsSource="{Binding Nodes}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <Canvas />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemContainerStyle>
          <Style TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding X}" />
            <Setter Property="Canvas.Top" Value="{Binding Y}" />
          </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:NodeViewModel}">
            <Border BorderThickness="2" CornerRadius="12" Width="200" Height="Auto" Margin="5"
                    PreviewMouseDown="Node_PreviewMouseDown"
                    MouseMove="Node_MouseMove"
                    MouseUp="Node_MouseUp"
                    Cursor="SizeAll">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="BorderBrush" Value="Transparent" />
                  <Setter Property="Background" Value="{Binding Metadata.CategoryColor}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                      <Setter Property="BorderBrush" Value="#FFFFFF" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsExecuting}" Value="True">
                      <Setter Property="BorderBrush" Value="#EAB308" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding HasError}" Value="True">
                      <Setter Property="BorderBrush" Value="#EF4444" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              
              <Grid Margin="12,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Input Pin (Projecting slightly outside left border) -->
                <ItemsControl Grid.Column="0" ItemsSource="{Binding InputPins}" HorizontalAlignment="Left" VerticalAlignment="Center">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <ContentControl Style="{StaticResource PinDotStyle}" Margin="-18,0,0,0"
                                      PreviewMouseLeftButtonDown="Pin_PreviewMouseLeftButtonDown"
                                      PreviewMouseLeftButtonUp="Pin_PreviewMouseLeftButtonUp"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Central Content Area -->
                <StackPanel Grid.Column="1" Margin="4,2">
                  <!-- Block Title -->
                  <TextBlock Text="{Binding Metadata.Name}" Foreground="White" FontWeight="Bold" FontFamily="Nunito" FontSize="13" Margin="0,0,0,6"/>
                  
                  <!-- Parameter Inputs list -->
                  <ItemsControl ItemsSource="{Binding InputPins}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                          <TextBlock Text="{Binding Label}" Foreground="#E2E8F0" FontSize="10" FontFamily="Nunito" VerticalAlignment="Center" Margin="0,0,5,0"/>
                          
                          <TextBox Width="75"
                                   Height="22"
                                   Background="#0F172A"
                                   Foreground="White"
                                   BorderThickness="0"
                                   Padding="4,2"
                                   FontSize="10"
                                   FontFamily="Nunito"
                                   VerticalContentAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Resources>
                              <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                              </Style>
                            </TextBox.Resources>
                          </TextBox>
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>

                <!-- Right Output Pin (Projecting slightly outside right border) -->
                <ItemsControl Grid.Column="2" ItemsSource="{Binding OutputPins}" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <ContentControl Style="{StaticResource PinDotStyle}" Margin="0,0,-18,0"
                                      PreviewMouseLeftButtonDown="Pin_PreviewMouseLeftButtonDown"
                                      PreviewMouseLeftButtonUp="Pin_PreviewMouseLeftButtonUp"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </local:NodeCanvas>
  </Grid>
</UserControl>
